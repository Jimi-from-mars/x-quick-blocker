{
  "manifest_version": 3,
  "name": "X Quick Block",
  "version": "1.0",
  "description": "按住Ctrl键点击推文快速屏蔽用户到官方屏蔽列表",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://twitter.com/*",
        "https://x.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}